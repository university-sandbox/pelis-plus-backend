# App
SERVER_PORT=8080

# Database
DB_NAME=pelisplus_db
DB_USERNAME=pelisplus_user
DB_PASSWORD=pelisplus_password

# DB_URL depends on how you run the app:
#
#   Local (mvn spring-boot:run / IDE):
#     DB_URL=jdbc:postgresql://localhost:5432/pelisplus_db
#
#   Docker standalone (docker run --env-file .env):
#     On Mac/Windows use host.docker.internal to reach host Postgres:
#     DB_URL=jdbc:postgresql://host.docker.internal:5432/pelisplus_db
#
#   Docker Compose (docker-compose up):
#     The compose file overrides this to use the postgres service name automatically.
#     DB_URL=jdbc:postgresql://postgres:5432/pelisplus_db
#
DB_URL=jdbc:postgresql://localhost:5432/pelisplus_db

# CORS — comma-separated list of allowed frontend origins
# Local:      CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# Production: CORS_ALLOWED_ORIGINS=https://pelisplus.nexoralabs.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# JWT (Base64-encoded secret, at least 256 bits)
JWT_SECRET=VGhpc0lzQVNlY3VyZUFuZExvbmdCYXNlNjRTZWNyZXRLZXlGb3JKV1Q=
JWT_EXPIRATION_MINUTES=60
JWT_ISSUER=pelis-plus

# Swagger/OpenAPI
SWAGGER_ENABLED=true
SWAGGER_UI_PATH=/swagger-ui.html
