# App
SERVER_PORT=8080

# Database
DB_NAME=pelisplus_db
DB_USERNAME=pelisplus_user
DB_PASSWORD=pelisplus_password

# DB_URL depends on how you run the app:
#
#   Local (mvn spring-boot:run / IDE):
#     DB_URL=jdbc:postgresql://localhost:5432/pelisplus_db
#
#   Docker standalone (docker run --env-file .env):
#     On Mac/Windows use host.docker.internal to reach host Postgres:
#     DB_URL=jdbc:postgresql://host.docker.internal:5432/pelisplus_db
#
#   Docker Compose (docker-compose up):
#     The compose file overrides this to use the postgres service name automatically.
#     DB_URL=jdbc:postgresql://postgres:5432/pelisplus_db
#
DB_URL=jdbc:postgresql://localhost:5432/pelisplus_db

# CORS — comma-separated list of allowed frontend origins
# Local:      CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# Production: CORS_ALLOWED_ORIGINS=https://pelisplus.nexoralabs.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# JWT (Base64-encoded secret, at least 256 bits)
JWT_SECRET=VGhpc0lzQVNlY3VyZUFuZExvbmdCYXNlNjRTZWNyZXRLZXlGb3JKV1Q=
JWT_EXPIRATION_MINUTES=216000
JWT_ISSUER=pelis-plus

# Swagger/OpenAPI
SWAGGER_ENABLED=true
SWAGGER_UI_PATH=/swagger-ui.html

# TMDB scheduled movie sync
# Runs every Sunday at 11:00 PM America/Lima by default.
# Prefer TMDB_ACCESS_TOKEN. TMDB_API_KEY is supported as a fallback.
TMDB_SYNC_ENABLED=true
TMDB_ACCESS_TOKEN=
TMDB_API_KEY=
TMDB_LANGUAGE=es-PE
TMDB_REGION=PE
TMDB_MAX_PAGES_PER_LIST=3
TMDB_RELEASE_LOOKBACK_DAYS=7
TMDB_MAX_RELEASE_LOOKBACK_DAYS=21
TMDB_SYNC_CRON=0 0 23 * * SUN
TMDB_TIME_ZONE=America/Lima

# Email delivery (Brevo SMTP)
# MAIL_SMTP_USERNAME is your Brevo SMTP login. MAIL_SMTP_KEY is the SMTP key
# generated in Brevo; it is not your Brevo account password.
# In test environments, all confirmation emails are sent only to
# MAIL_TEST_RECIPIENT, never to a purchaser's email address.
MAIL_ENABLED=false
MAIL_SMTP_HOST=smtp-relay.brevo.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_KEY=
MAIL_TEST_RECIPIENT=

# Stripe sandbox checkout
# Use a Stripe test secret key, for example sk_test_...
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=pen
STRIPE_SUCCESS_URL=http://localhost:4200/checkout/stripe/success?order_id={ORDER_ID}&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:4200/checkout?payment=cancelled
STRIPE_MEMBERSHIP_SUCCESS_URL=http://localhost:4200/memberships/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_MEMBERSHIP_CANCEL_URL=http://localhost:4200/memberships?payment=cancelled
