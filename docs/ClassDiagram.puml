' ══════════════════════════════════
'  RELATIONSHIPS
' ══════════════════════════════════

AppUser --> Role : role

Movie "*" --> "*" Genre           : genres

Room "*" --> "1" Venue            : venue
Room "*" --> "1" RoomType         : roomType
Room "*" --> "1" RoomLayout       : roomLayout

Screening "*" --> "1" Movie       : movie
Screening "*" --> "1" Room        : room

Seat "*" --> "1" Screening        : screening
SeatReservation "*" --> "1" Seat      : seat
SeatReservation "*" --> "1" AppUser   : user

SnackOption "*" --> "1" Snack         : snack
SnackChoice "*" --> "1" SnackOption   : option

MembershipPlanBenefit "*" --> "1" MembershipPlan : plan
ActiveMembership "0..1" --> "1" AppUser           : user
ActiveMembership "*" --> "1" MembershipPlan       : plan

Order "*" --> "1" AppUser             : user
OrderTicket "*" --> "1" Order         : order
OrderTicket "*" --> "1" Screening     : screening
OrderTicket "*" --> "1" Seat          : seat
OrderSnack "*" --> "1" Order          : order
OrderSnack "*" --> "1" Snack          : snack
Ticket "1" --> "1" OrderTicket        : orderTicket
Ticket "*" --> "1" Order              : order

@enduml
