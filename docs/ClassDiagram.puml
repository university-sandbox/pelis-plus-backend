@startuml ClassDiagram
title PelisPlus — Class Diagram (Domain Entities)

skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #2C3E50
skinparam classHeaderBackgroundColor #D6E4F0
skinparam classHeaderFontColor #1A1A1A
skinparam classFontColor #1A1A1A
skinparam classFontSize 12
skinparam classHeaderFontSize 13
skinparam arrowColor #2C3E50
skinparam arrowThickness 1.5
skinparam linetype polyline
skinparam nodesep 70
skinparam ranksep 90
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam titleFontColor #1A1A1A
skinparam titleFontSize 16
skinparam packageBackgroundColor #F0F4F8
skinparam packageBorderColor #2C3E50
skinparam packageFontColor #1A1A1A

hide circle

' ══════════════════════════════════
'  DOMAIN
' ══════════════════════════════════
package "domain" {
  enum Role {
    USER
    ADMIN
  }

  class AppUser {
    - id : UUID
    - name : String
    - email : String
    - password : String
    - role : Role
    - createdAt : Instant
    --
    + getId() : UUID
    + getName() : String
    + setName(String) : void
    + getEmail() : String
    + setEmail(String) : void
    + getPassword() : String
    + setPassword(String) : void
    + getRole() : Role
    + setRole(Role) : void
    + getCreatedAt() : Instant
  }
}

' ══════════════════════════════════
'  MOVIE
' ══════════════════════════════════
package "movie" {
  class Movie {
    - id : Long
    - title : String
    - overview : String
    - posterPath : String
    - backdropPath : String
    - releaseDate : String
    - voteAverage : Double
    - voteCount : Integer
    - runtime : Integer
    - originalLanguage : String
    - popularity : Double
    - adult : Boolean
    - video : Boolean
    - trailerYoutubeKey : String
    - status : String
    - active : Boolean
    - genres : List<Genre>
    --
    + getId() : Long
    + setId(Long) : void
    + getTitle() : String
    + setTitle(String) : void
    + getOverview() : String
    + setOverview(String) : void
    + getPosterPath() : String
    + setPosterPath(String) : void
    + getBackdropPath() : String
    + setBackdropPath(String) : void
    + getReleaseDate() : String
    + setReleaseDate(String) : void
    + getVoteAverage() : Double
    + setVoteAverage(Double) : void
    + getVoteCount() : Integer
    + setVoteCount(Integer) : void
    + getRuntime() : Integer
    + setRuntime(Integer) : void
    + getOriginalLanguage() : String
    + setOriginalLanguage(String) : void
    + getPopularity() : Double
    + setPopularity(Double) : void
    + getAdult() : Boolean
    + setAdult(Boolean) : void
    + getVideo() : Boolean
    + setVideo(Boolean) : void
    + getTrailerYoutubeKey() : String
    + setTrailerYoutubeKey(String) : void
    + getStatus() : String
    + setStatus(String) : void
    + getActive() : Boolean
    + setActive(Boolean) : void
    + getGenres() : List<Genre>
    + setGenres(List<Genre>) : void
  }

  class Genre {
    - id : Long
    - name : String
    --
    + getId() : Long
    + setId(Long) : void
    + getName() : String
    + setName(String) : void
  }
}

